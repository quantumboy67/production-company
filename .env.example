NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Optional local-only helper for `npm run types:supabase`.
SUPABASE_PROJECT_ID=your-project-ref

# Required for server-only invite/user management.
# Never expose service role keys in NEXT_PUBLIC variables.
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key

# Optional server-only invitation request email notifications.
# Leave blank to store requests without sending email.
INVITE_REQUEST_NOTIFY_EMAIL=
INVITE_REQUEST_FROM_EMAIL=
RESEND_API_KEY=
